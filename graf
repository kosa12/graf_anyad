#include <iostream>
#include <vector>

using namespace std;


int m[10][10];
int n = 8;

bool van(int x, int y)
{
    if(m[x][y]==1)
    {
        return true;
    }
    return false;
}

int graf(int csomopont){
    int s=0;
    for(int i=1; i<=n;i++){
        s=s+m[i][csomopont];

    }
    return s;
}

int main()
{

    int i, j;
    for(i=0; i<n; i++)
    {
        for(j=0; j<n; j++)
        {
            m[i][j]=0;
        }
    }

    m[1][2] = 1;
    m[1][6] = 1;
    m[2][3] = 1;
    m[2][4] = 1;
    m[3][4]= 1;
    m[4][8]= 1;
    m[5][6]= 1;
    m[5][7]= 1;
    m[5][8]= 1;

    for(i=0; i<n-1; i++)
    {
        for(j=i+1; j<n; j++)
        {
            m[j][i]= m[i][j];
        }
    }

    for(i=0; i<n; i++)
    {
        for(j=0; j<n; j++)
        {
            cout << m[i][j] << " ";
        }
        cout << endl;
    }
    cout<<van(1, 8)<<endl;
    cout<<graf(2);

    return 0;
}
